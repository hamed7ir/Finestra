<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{B8E7C1A2-3D4F-4A56-9B0C-1E2F3A4B5C6D}</ProjectGuid>
    <OutputType>WinExe</OutputType>
    <RootNamespace>Finestra</RootNamespace>
    <AssemblyName>Finestra</AssemblyName>
    <TargetFrameworkVersion>v4.7</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <!-- ONE universal managed assembly: AnyCPU + Prefer32Bit runs as 32-bit on x64 (WoW64) and as native
         ARM32 on Windows RT 8.1 / Win10 ARM32 (Prefer32Bit is ignored on ARM). Deploying to ARM = copying
         this exact .exe. NO separate ARM build. -->
    <PlatformTarget>AnyCPU</PlatformTarget>
    <Prefer32Bit>true</Prefer32Bit>
    <LangVersion>7.3</LangVersion>
    <!-- Source files are UTF-8 (no BOM); force the compiler to read them as UTF-8 so non-ASCII in string
         literals (—, …) isn't mojibaked to the system codepage. -->
    <CodePage>65001</CodePage>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <GenerateBindingRedirectsOutputType>true</GenerateBindingRedirectsOutputType>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <TargetFrameworkProfile />
    <!-- The exe's own icon (Explorer / taskbar default). The multi-size .ico (16/32/48/64/128/256) lives at the
         repo root; it is ALSO embedded below so forms + the tray NotifyIcon load every size at runtime. -->
    <ApplicationIcon>..\Finestra.ico</ApplicationIcon>
  </PropertyGroup>
  <!-- DEBUG is the config we build AND deploy: [PATHS]/[ACCENT]/[DPI] diagnostics are Debug.WriteLine, so an
       on-device DEBUG build is what makes RT accent verification readable from the log file. -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Data" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Security" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Xml" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>
  <ItemGroup>
    <!-- Direct reference to the DLL already in the NuGet global cache. This standalone MSBuild has no NuGet
         restore targets and the box has no nuget.exe/internet guarantee, so a HintPath is the deterministic
         way to bind Newtonsoft.Json. Assembly version is 13.0.0.0 (Newtonsoft pins it across 13.x), so no
         binding redirect is required. net45 lib = correct TFM for our net47 target. -->
    <Reference Include="Newtonsoft.Json">
      <HintPath>$(USERPROFILE)\.nuget\packages\newtonsoft.json\13.0.4\lib\net45\Newtonsoft.Json.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
  <!-- SSH track (FRDP-SSH-BUILD-1): SSH.NET 2025.1.0 + VtNetCore net46 + the modern-BCL facade stack, staged in
       lib\ (device-confirmed on RT 8.1 ARM32 — FRDP-DEVICE-2 S1). HintPath because this standalone MSBuild has no
       NuGet restore; AutoGenerateBindingRedirects (above) writes the facade redirects into Finestra.exe.config. -->
  <ItemGroup>
    <Reference Include="Renci.SshNet"><HintPath>lib\Renci.SshNet.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="VtNetCore"><HintPath>lib\VtNetCore.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="BouncyCastle.Cryptography"><HintPath>lib\BouncyCastle.Cryptography.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="System.Formats.Asn1"><HintPath>lib\System.Formats.Asn1.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="System.Memory"><HintPath>lib\System.Memory.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="System.Buffers"><HintPath>lib\System.Buffers.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="System.Numerics.Vectors"><HintPath>lib\System.Numerics.Vectors.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="System.Runtime.CompilerServices.Unsafe"><HintPath>lib\System.Runtime.CompilerServices.Unsafe.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="System.Threading.Tasks.Extensions"><HintPath>lib\System.Threading.Tasks.Extensions.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="System.ValueTuple"><HintPath>lib\System.ValueTuple.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="Microsoft.Extensions.Logging.Abstractions"><HintPath>lib\Microsoft.Extensions.Logging.Abstractions.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="Microsoft.Extensions.DependencyInjection.Abstractions"><HintPath>lib\Microsoft.Extensions.DependencyInjection.Abstractions.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="Microsoft.Bcl.AsyncInterfaces"><HintPath>lib\Microsoft.Bcl.AsyncInterfaces.dll</HintPath><Private>true</Private></Reference>
    <Reference Include="System.Diagnostics.DiagnosticSource"><HintPath>lib\System.Diagnostics.DiagnosticSource.dll</HintPath><Private>true</Private></Reference>
  </ItemGroup>
  <!-- FTP track (FRDP-FTP-BUILD-1): FluentFTP 54.2.0 net462 — MIT, ZERO dependencies (refs only mscorlib/System/
       System.Core), FTPS via in-box SslStream. One self-contained DLL, so NO binding redirects are needed (unlike
       the SSH.NET facade stack). RT-representative 32-bit run proven in FRDP-FTP-RECON; device pass pending. -->
  <ItemGroup>
    <Reference Include="FluentFTP"><HintPath>lib\FluentFTP.dll</HintPath><Private>true</Private></Reference>
  </ItemGroup>
